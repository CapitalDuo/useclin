# ============================================================
# SUPABASE (obrigatório)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Server-only. NUNCA prefixar com NEXT_PUBLIC_ — vazaria pro browser.
# Necessário pra criar usuários da equipe via admin API (feature de Equipe).
# Pegue em: Supabase Dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# N8N (automação WhatsApp)
# ============================================================
# URL do webhook unificado no n8n. Nunca expor com NEXT_PUBLIC_.
N8N_WEBHOOK_URL=https://seu-n8n.host/webhook/whatsapp
# Secret enviada no header x-webhook-secret — precisa bater com o IF hardcoded
# no workflow n8n (fluxo_completo_conectar). Gere com: openssl rand -hex 32
N8N_WEBHOOK_SECRET=

# ============================================================
# UPSTASH REDIS (opcional — rate limit)
# ============================================================
# Sem essas vars, rate limit fica desativado (fail-open, log warning).
# Provisione via Vercel Marketplace → Upstash Redis (free tier).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================
# STRIPE (billing)
# ============================================================
# Chaves em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Webhook secret gerado em: Stripe Dashboard → Webhooks → seu endpoint
STRIPE_WEBHOOK_SECRET=whsec_...
# IDs dos preços criados no Stripe Dashboard (Products → seu produto → Price ID)
STRIPE_PRICE_BASICO=price_...
STRIPE_PRICE_COMPLETO=price_...
